NODE_ENV=development 
PORT=3501

DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=database_name
DB_HOST=127.0.0.1
DB_DIALECT=mysql
DB_PORT=3306
MAX_CONNECTION=10

# Email configuration
EMAIL_HOST=hostname
EMAIL_PORT=port
SMTS_USERNAME=username
SMTP_PASSWORD=password
EMAIL_FROM=xyz@traitfit.com

# SMS configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number